{
  "name": "termdash",
  "version": "1.1.0",
  "description": "Deploy a coordinated swarm of Claude Code agents on any project — runs on your own Claude. A local terminal dashboard with session tiles and launcher shortcuts.",
  "main": "main.js",
  "license": "MIT",
  "author": "thaerthebear",
  "repository": {
    "type": "git",
    "url": "https://github.com/thaerthebear/termdash.git"
  },
  "homepage": "https://github.com/thaerthebear/termdash",
  "bugs": {
    "url": "https://github.com/thaerthebear/termdash/issues"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win",
    "pack": "electron-builder --win --dir"
  },
  "build": {
    "appId": "com.termdash.app",
    "productName": "TermDash",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "npmRebuild": false,
    "files": [
      "main.js",
      "preload.js",
      "sessions.default.js",
      "src/**/*",
      "node_modules/**/*",
      "!node_modules/node-pty/build/Release/*.pdb",
      "!node_modules/node-pty/build/Release/*.iobj",
      "!node_modules/node-pty/build/Release/*.ipdb",
      "!node_modules/node-pty/build/Release/*.exp",
      "!node_modules/node-pty/build/Release/*.lib",
      "!node_modules/node-pty/build/Release/obj/**"
    ],
    "asarUnpack": [
      "node_modules/node-pty/**"
    ],
    "artifactName": "TermDash-Setup-${version}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "thaerthebear",
        "repo": "termdash"
      }
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "TermDash"
    }
  },
  "dependencies": {
    "@babel/standalone": "^7.24.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@electron/node-gyp": "^10.2.0-electron.2",
    "@electron/rebuild": "^4.0.4",
    "electron": "^33.4.0",
    "electron-builder": "^26.15.3",
    "electron-rebuild": "^3.2.9"
  }
}
